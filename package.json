{
  "name": "@cdx-foundation/cdx-solidjs-components",
  "version": "1.0.0",
  "description": "Solid.js component library for CDX projects.",
  "repository": {
    "type": "git",
    "url": "https://github.com/cdx-foundation/cdx-solidjs-components.git"
  },
  "style": "./lib/theme.css",
  "source": "lib/index.ts",
  "files": [
    "dist",
    "lib",
    "README.md"
  ],
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "main": "./dist/index.cjs.js",
  "module": "./dist/index.esm.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "style": "./lib/theme.css",
      "solid": "./lib/index.ts",
      "development": "./lib/index.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs.js"
    },
    "./ui/*": {
      "types": "./dist/types/ui/*.d.ts",
      "import": "./lib/ui/*.tsx"
    },
    "./hooks": {
      "types": "./dist/types/hooks/index.d.ts",
      "development": "./lib/hooks/index.ts",
      "import": "./dist/hooks.esm.js"
    },
    "./theme": "./lib/theme.css"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "dev": "vp dev",
    "build": "vp build && tsc -p tsconfig.prod.json",
    "build:demo": "BUILD_DEMO=true vp build",
    "lint": "vp lint",
    "fmt": "vp fmt",
    "typecheck": "tsc --noEmit",
    "test": "vp test run",
    "test:watch": "vp test",
    "prepare": "vp config"
  },
  "dependencies": {
    "@solid-primitives/event-listener": "^2.4.5",
    "@solid-primitives/keyboard": "^1.3.5",
    "@solid-primitives/media": "^2.3.5",
    "@solid-primitives/storage": "^4.3.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-solid": "^1.18.0",
    "solid-transition-group": "^0.3.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/npm": "^13.1.5",
    "@solidjs/testing-library": "^0.8.10",
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/bun": "^1.3.14",
    "jsdom": "^29.1.1",
    "semantic-release": "^25.0.5",
    "solid-js": "^1.9.13",
    "tailwindcss": "^4.3.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-solid": "^2.11.12",
    "vite-plus": "latest",
    "vitest": "4.1.9"
  },
  "peerDependencies": {
    "solid-js": "^1.9.12"
  },
  "devEngines": {
    "packageManager": {
      "name": "npm",
      "version": ">=11.0.0"
    }
  },
  "solid": "./lib/index.ts"
}
