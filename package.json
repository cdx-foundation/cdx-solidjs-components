{
  "name": "starling-components",
  "version": "2.0.2",
  "description": "Solid.js component library for Starling City projects.",
  "type": "module",
  "sideEffects": ["*.css"],
  "main": "./dist/index.cjs.js",
  "module": "./dist/index.esm.js",
  "solid": "./lib/index.ts",
  "style": "./lib/theme.css",
  "types": "./dist/types/index.d.ts",
  "source": "lib/index.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "style": "./lib/theme.css",
      "solid": "./lib/index.ts",
      "development": "./lib/index.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs.js"
    },
    "./ui/*": {
      "types": "./dist/types/ui/*.d.ts",
      "import": "./lib/ui/*.tsx"
    },
    "./hooks": {
      "types": "./dist/types/hooks/index.d.ts",
      "development": "./lib/hooks/index.ts",
      "import": "./dist/hooks.esm.js"
    },
    "./theme": "./lib/theme.css"
  },
  "files": ["dist", "lib", "README.md"],
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc -p tsconfig.prod.json",
    "lint": "biome check .",
    "fmt": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@solid-primitives/event-listener": "^2.4.5",
    "@solid-primitives/keyboard": "^1.3.5",
    "@solid-primitives/media": "^2.3.5",
    "@solid-primitives/storage": "^4.3.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-solid": "^1.8.0",
    "solid-transition-group": "^0.3.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "peerDependencies": {
    "solid-js": "^1.9.12"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@solidjs/testing-library": "^0.8.10",
    "@tailwindcss/vite": "^4.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/bun": "^1.3.13",
    "jsdom": "^29.0.2",
    "solid-js": "^1.9.12",
    "tailwindcss": "^4.2.4",
    "tsup": "^8.4.0",
    "typescript": "^6.0.3",
    "vite-plugin-dts": "^4.3.0",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^4.1.5"
  }
}
